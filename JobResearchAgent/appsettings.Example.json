{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    },
      "ConnectionStrings": {
        "Default": "Host=localhost;Port=5432;Database=jobsdb;Username=your_db_user;Password=your_db_password"
    }
  },
    "AI": {
    "Provider": "OpenAI",
    "EmbeddingModel": "text-embedding-3-small",
    "Model": "gpt-4o-mini"
  },
  "AgentPolicy": {
    "Countries": [
        "United States", "Canada"
      ],
      "Keywords": [
        "Software Engineer", "Full Stack Developer", "Backend Developer"
      ],
      "Levels": [
        "Mid", "Senior", "Lead"
      ],
      "MaxAgeHours": 48,
      "RemoteOnly": false,
      "AllowHybrid": true
  },
  "MatchingConfiguration": {
    "MinimumSimilarityThreshold": 0.35,
    "ApplyThreshold": 75,
    "ReviewThreshold": 60,
    "QualificationThreshold": 70
  },
  "Output": {
    "BasePath": "C:\\JobApplications"
  },
  "Candidate": {
    "FullName": "John Doe",
    "PhoneBR": "BR: +55 11 91234-5678",
    "PhoneUS": "US: +1-555-0100",
    "PhoneCA": "CA: +1-555-0101",
    "Phone": "US: +1-555-0100",
    "LocationBR": "São Paulo, SP, Brazil",
    "LocationUS": "San Francisco, CA, USA",
    "LocationCA": "Toronto, ON, Canada",
    "Location": "San Francisco, CA, USA",
    "Email": "john.doe@example.com",
    "LinkedIn": "https://linkedin.com/in/johndoe",
    "PersonalWebsite": "https://johndoe.dev",
    "Education": [
      "University Name | Degree Name | Year - Year",
      "College Name | Certificate/Diploma | Year - Year"
    ],
    "Career": {
      "StartYear": "Year",
      "EarlyCareerLabel": "Job Title - Various companies",
      "Description": "Brief description of early career experience and technologies used."
    }
  },
  "ApplicationPolicy": {
    "Enabled": false,
    "RequireApproval": true,
    "AutoSubmit": false,
    "DelayBetweenApplicationsSeconds": 30,
    "DocumentsBasePath": "C:\\JobApplications",
    "ScreenshotOnFailure": true,
    "AllowedCompany": ""
  },
  "BrowserAutomation": {
    "Headless": false,
    "SlowMoMs": 150,
    "TimeoutMs": 60000,
    "UserDataDir": "playwright-profile",
    "Viewport": {
      "Width": 1400,
      "Height": 900
    }
  },
  "IndeedAutomation": {
    "ApplyButtonSelector": "button[data-testid='indeedApplyButton']",
    "ResumeUploadSelector": "input[type='file']",
    "CoverLetterUploadSelector": "input[name='coverletter']",
    "SubmitButtonSelector": "button[type='submit']",
    "SuccessIndicatorSelector": "[data-testid='application-confirmation']",

    "AdditionalFields": [
      {
        "Selector": "input[name='applicant.name']",
        "Value": "John Doe"
      },
      {
        "Selector": "input[name='applicant.email']",
        "Value": "john.doe@example.com"
      }
    ]
  }
}
